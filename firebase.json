{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "storage.rules",
      "**/.*",
      "functions/**",
      "README.md",
      "video/Header web old.mp4",
      "Frost/**"
    ],
    "headers": [
      {
        "source": "**/*.@(webp|jpg|jpeg|png|gif|mp4|ttf|woff2)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ],
    "redirects": [
      { "source": "/kostymy{,/**}", "destination": "/#kostymy", "type": 301 },
      { "source": "/kontakty{,/**}", "destination": "/#kontakt", "type": 301 },
      { "source": "/wh-kontakt{,/**}", "destination": "/#kontakt", "type": 301 },
      { "source": "/o-akci{,/**}", "destination": "/#proc", "type": 301 },
      { "source": "/partneri{,/**}", "destination": "/#partneri", "type": 301 },
      { "source": "/vstupenky{,/**}", "destination": "/#vstupenky", "type": 301 },
      { "source": "/naposlednichvili{,/**}", "destination": "/#vstupenky", "type": 301 },
      { "source": "/soutez**", "destination": "/#soutez", "type": 301 },
      { "source": "/report{,/**}", "destination": "/#historie", "type": 301 },
      { "source": "/promo**", "destination": "/", "type": 301 },
      { "source": "/praha{,/**}", "destination": "/", "type": 301 },
      { "source": "/brno{,/**}", "destination": "/", "type": 301 },
      { "source": "/homepage{,/**}", "destination": "/", "type": 301 },
      { "source": "/donate{,/**}", "destination": "/", "type": 301 },
      { "source": "/donation**", "destination": "/", "type": 301 },
      { "source": "/author/**", "destination": "/", "type": 301 },
      { "source": "/friends{,/**}", "destination": "/", "type": 301 },
      { "source": "/test{,/**}", "destination": "/", "type": 301 },
      { "source": "/feed{,/**}", "destination": "/", "type": 301 },
      { "source": "/feeds/**", "destination": "/", "type": 301 },
      { "source": "/comments/**", "destination": "/", "type": 301 },
      { "source": "/@(feed.xml|atom.xml|index.xml)", "destination": "/", "type": 301 },
      { "source": "/en/contacts{,/**}", "destination": "/?lang=en#kontakt", "type": 301 },
      { "source": "/en/contest{,/**}", "destination": "/?lang=en#soutez", "type": 301 },
      { "source": "/en/event{,/**}", "destination": "/?lang=en#program", "type": 301 },
      { "source": "/en/tickets{,/**}", "destination": "/?lang=en#vstupenky", "type": 301 },
      { "source": "/en{,/**}", "destination": "/?lang=en", "type": 301 },
      { "source": "/@(sitemap_index.xml|page-sitemap.xml)", "destination": "/sitemap.xml", "type": 301 },
      { "source": "/wp-admin/**", "destination": "/", "type": 301 },
      { "source": "/wp-content/**", "destination": "/", "type": 301 },
      { "source": "/wp-includes/**", "destination": "/", "type": 301 },
      { "source": "/wp-login.php", "destination": "/", "type": 301 }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
